{
  "name": "@mastors/gridder",
  "version": "1.2.7",
  "description": "Mastors Gridder — complete CSS Grid utility class system",
  "license": "MIT",
  "author": "Mastors Contributors",
  "homepage": "https://mastorscdn.kehem.com/packages/gridder",
  "repository": {
    "type": "git",
    "url": "https://github.com/KEHEM-IT/Mastors.git",
    "directory": "packages/gridder"
  },
  "keywords": [
    "mastors",
    "gridder",
    "grid",
    "css-grid",
    "scss",
    "utilities",
    "css-framework"
  ],
  "sass": "./scss/index.scss",
  "style": "./dist/mastors-gridder.css",
  "exports": {
    ".": {
      "sass": "./scss/index.scss",
      "style": "./dist/mastors-gridder.css"
    },
    "./scss": "./scss/index.scss",
    "./scss/*": "./scss/*"
  },
  "files": [
    "_index.scss",
    "dist",
    "postinstall.js",
    "preuninstall.js",
    "scss",
    "README.md"
  ],
  "scripts": {
    "build": "node build.js",
    "build:prod": "node build.js --prod",
    "dev": "node build.js --watch",
    "clean": "rimraf dist",
    "preuninstall": "node preuninstall.js",
    "postinstall": "node postinstall.js"
  },
  "devDependencies": {
    "@mastors/build-utils": "workspace:*",
    "@mastors/sass-config": "workspace:*",
    "rimraf": "^5.0.0",
    "sass": "^1.80.0"
  },
  "peerDependencies": {
    "@mastors/core": ">=1.0.0",
    "sass": ">=1.80.0"
  },
  "peerDependenciesMeta": {
    "sass": { "optional": true }
  },
  "sideEffects": [
    "dist/*.css",
    "scss/**/*.scss"
  ]
}
