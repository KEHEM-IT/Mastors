{
  "name": "@mastors/core",
  "version": "1.2.1",
  "description": "Mastors Core — foundational tokens, mixins, functions, and SCSS architecture",
  "license": "MIT",
  "author": "Mastors Contributors",
  "homepage": "https://mastorscdn.kehem.com/packages/core",
  "repository": {
    "type": "git",
    "url": "https://github.com/KEHEM-IT/Mastors.git",
    "directory": "packages/core"
  },
  "keywords": [
    "mastors",
    "core",
    "scss",
    "tokens",
    "design-system",
    "css-framework"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sass": "./scss/index.scss",
  "style": "./dist/mastors-core.css",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./scss": "./scss/index.scss",
    "./scss/*": "./scss/*",
    "./api": "./scss/api/_index.scss",
    "./dist/mastors-core.css": "./dist/mastors-core.css"
  },
  "files": [
    "api",
    "dist",
    "postinstall.js",
    "scripts",
    "scss",
    "README.md"
  ],
  "scripts": {
    "build": "node build.js",
    "build:prod": "node build.js --prod",
    "dev": "node build.js --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "stylelint \"scss/**/*.scss\" --custom-syntax postcss-scss",
    "postinstall": "node postinstall.js"
  },
  "devDependencies": {
    "@mastors/build-utils": "workspace:*",
    "@mastors/sass-config": "workspace:*",
    "@mastors/tsconfig": "workspace:*",
    "@types/node": "^20.0.0",
    "postcss-scss": "^4.0.0",
    "rimraf": "^5.0.0",
    "sass": "^1.80.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "sass": ">=1.80.0"
  },
  "sideEffects": [
    "dist/*.css",
    "scss/**/*.scss"
  ]
}
